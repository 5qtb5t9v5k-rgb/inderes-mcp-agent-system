# env / secrets — NEVER commit
.env
.env.local
*.pem
*.key
.streamlit/secrets.toml

# venv / Python build artifacts
.venv/
venv/
# uv.lock — intentionally ignored. Streamlit Cloud prefers uv-sync uv.lock when
# present, but our deploy uses requirements.txt (which has the [ui] extra deps
# like streamlit inlined). Committing uv.lock causes Streamlit Cloud to switch
# installers and drop streamlit. Keep requirements.txt as the source of truth.
uv.lock
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings (user-specific permission grants)
.claude/settings.local.json

# Logs and OAuth caches (these live in $HOME by default; here as belt-and-braces)
*.log
.tokens.json
.inderes_oauth_cache/
.inderes_agent/
