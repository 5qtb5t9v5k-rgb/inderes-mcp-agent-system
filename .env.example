# Gemini API — get free key at https://aistudio.google.com/
GEMINI_API_KEY=

# Inderes MCP
INDERES_MCP_URL=https://mcp.inderes.com
INDERES_MCP_CLIENT_ID=inderes-mcp

# Models — free-tier reality (see BUILD_SPEC.md §2.1, §6.8)
PRIMARY_MODEL=gemini-3.1-flash-lite-preview
FALLBACK_MODEL=gemini-2.5-flash

# Fallback behavior
RETRY_DELAY_MS=1000
MAX_RETRIES=1

# Concurrency control (protects against free-tier quota burn)
MAX_CONCURRENT_AGENTS=2

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
